[Unit]
Description=noop API Server
After=network.target postgresql.service
Requires=postgresql.service

[Service]
Type=simple
User=netmon
Group=netmon
WorkingDirectory=/opt/netmon/noop/backend
EnvironmentFile=/etc/netmon/netmon.env
ExecStart=/opt/netmon/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --workers 2
Restart=on-failure
RestartSec=10
StandardOutput=journal
StandardError=journal
SyslogIdentifier=netmon-api

[Install]
WantedBy=multi-user.target
